# Copy to .env and fill in. .env is gitignored.

# --- Database ---
# Local docker-compose: postgresql+asyncpg://aiapi:aiapi@localhost:5432/aiapi
DATABASE_URL=postgresql+asyncpg://aiapi:aiapi@localhost:5432/aiapi

# --- Admin API ---
# Bootstrap admin token for protecting /admin/** endpoints in Phase 1.
ADMIN_BOOTSTRAP_TOKEN=local-dev-admin-only

# --- Azure OpenAI ---
# Resource endpoint (no trailing slash), key, API version, and a deployment name to test against.
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-06-01
# A deployment name in your Azure OpenAI resource for tests/quickstart (e.g. gpt-4o-mini-prod).
AZURE_OPENAI_TEST_MODEL=gpt-4o-mini

# --- App ---
LOG_LEVEL=INFO

# --- Phase 2: Auth ---
BASE_URL=http://localhost:8000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Google OIDC (leave blank to disable the provider locally)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# --- Phase 2.5: Hardening ---
# ALLOWED_PROVIDERS='["azure","anthropic"]'   # JSON array; empty list → service fail-fast
# ANOMALY_CHECK_INTERVAL_MIN=5
# ANOMALY_THRESHOLD_MULTIPLIER=10.0
# ANOMALY_ABSOLUTE_COLD_START=10000
# ANOMALY_MIN_CALLS=100
# PERIP_LOCKOUT_THRESHOLD=10
