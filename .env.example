# Copy to .env and fill in. .env is gitignored.

# --- Database ---
# Local docker-compose: postgresql+asyncpg://aiapi:aiapi@localhost:5432/aiapi
DATABASE_URL=postgresql+asyncpg://aiapi:aiapi@localhost:5432/aiapi

# --- Admin API ---
# Bootstrap admin token for protecting /admin/** endpoints in Phase 1.
ADMIN_BOOTSTRAP_TOKEN=local-dev-admin-only

# --- Azure OpenAI ---
# Resource endpoint (no trailing slash), key, API version, and a deployment name to test against.
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-06-01
# A deployment name in your Azure OpenAI resource for tests/quickstart (e.g. gpt-4o-mini-prod).
AZURE_OPENAI_TEST_MODEL=gpt-4o-mini

# --- App ---
LOG_LEVEL=INFO
